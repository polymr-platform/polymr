    <groupId>be.celerex</groupId>
    <artifactId>polymr-backend</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <name>polymr-backend</name>

    <properties>
        <compiler-plugin.version>3.15.0</compiler-plugin.version>
        <maven.compiler.release>21</maven.compiler.release>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
        <quarkus.platform.artifact-id>quarkus-bom</quarkus.platform.artifact-id>
        <quarkus.platform.group-id>io.quarkus.platform</quarkus.platform.group-id>
        <quarkus.platform.version>3.36.1</quarkus.platform.version>
        <skipITs>true</skipITs>
        <surefire-plugin.version>3.5.4</surefire-plugin.version>
        <langchain4j.version>1.14.0</langchain4j.version>
        <graalvm.version>25.0.3</graalvm.version>
        <frontend.workingDirectory>${project.basedir}/../frontend</frontend.workingDirectory>
        <frontend.distDirectory>${frontend.workingDirectory}/dist</frontend.distDirectory>
        <frontend.outputDirectory>${project.build.outputDirectory}/META-INF/resources</frontend.outputDirectory>
		<polymr.database.variant>postgresql</polymr.database.variant>
		<polymr.build.suffix>postgresql</polymr.build.suffix>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>${quarkus.platform.group-id}</groupId>
