    <build>
		<finalName>${project.artifactId}-${project.version}-${polymr.build.suffix}</finalName>
        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <filtering>true</filtering>
            </resource>
        </resources>
        <plugins>
            <plugin>
                <groupId>${quarkus.platform.group-id}</groupId>
                <artifactId>quarkus-maven-plugin</artifactId>
                <version>${quarkus.platform.version}</version>
                <extensions>true</extensions>
                <executions>
                    <execution>
                        <goals>
                            <goal>build</goal>
                            <goal>generate-code</goal>
                            <goal>generate-code-tests</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        <plugin>
                <artifactId>maven-resources-plugin</artifactId>
                <version>3.3.1</version>
                <configuration>
                    <delimiters>
                        <delimiter>@</delimiter>
                    </delimiters>
                    <useDefaultDelimiters>false</useDefaultDelimiters>
                </configuration>
            </plugin>
            <plugin>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${compiler-plugin.version}</version>
                <configuration>
                    <parameters>true</parameters>
                </configuration>
            </plugin>
            <plugin>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>${surefire-plugin.version}</version>
                <configuration>
                    <systemPropertyVariables>
                        <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>
                        <maven.home>${maven.home}</maven.home>
                    </systemPropertyVariables>
                </configuration>
            </plugin>
            <plugin>
                <artifactId>maven-failsafe-plugin</artifactId>
                <version>${surefire-plugin.version}</version>
                <executions>
                    <execution>
                        <goals>
                            <goal>integration-test</goal>
                            <goal>verify</goal>
                        </goals>
                    </execution>
                </executions>
                <configuration>
                    <systemPropertyVariables>
                        <native.image.path>${project.build.directory}/${project.build.finalName}-runner</native.image.path>
                        <java.util.logging.manager>org.jboss.logmanager.LogManager</java.util.logging.manager>
                        <maven.home>${maven.home}</maven.home>
                    </systemPropertyVariables>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <profile>
            <id>build</id>
            <activation>
                <property>
                    <name>quarkus.profile</name>
                    <value>prod</value>
                </property>
            </activation>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-clean-plugin</artifactId>
                        <version>3.5.0</version>
                        <configuration>
                            <filesets>
                                <fileset>
                                    <directory>${frontend.outputDirectory}</directory>
                                </fileset>
                            </filesets>
                        </configuration>
                    </plugin>
                    <plugin>
                        <groupId>org.codehaus.mojo</groupId>
                        <artifactId>exec-maven-plugin</artifactId>
                        <version>3.6.2</version>
                        <executions>
                            <execution>
                                <id>frontend-install</id>
                                <phase>generate-resources</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <workingDirectory>${frontend.workingDirectory}</workingDirectory>
                                    <executable>bash</executable>
                                    <arguments>
                                        <argument>-lc</argument>
                                        <argument>if [ -f package-lock.json ]; then npm ci; else npm install; fi</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                            <execution>
                                <id>frontend-build</id>
                                <phase>generate-resources</phase>
                                <goals>
                                    <goal>exec</goal>
                                </goals>
                                <configuration>
                                    <workingDirectory>${frontend.workingDirectory}</workingDirectory>
                                    <executable>npm</executable>
                                    <arguments>
                                        <argument>run</argument>
                                        <argument>build</argument>
                                    </arguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                    <plugin>
                        <artifactId>maven-resources-plugin</artifactId>
                        <version>3.3.1</version>
                        <executions>
                            <execution>
                                <id>copy-frontend-dist</id>
                                <phase>process-resources</phase>
                                <goals>
                                    <goal>copy-resources</goal>
                                </goals>
                                <configuration>
                                    <outputDirectory>${frontend.outputDirectory}</outputDirectory>
                                    <resources>
                                        <resource>
                                            <directory>${frontend.distDirectory}</directory>
                                        </resource>
                                    </resources>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
        </profile>
	<profile>
		<id>packaging</id>
		<properties>
			<quarkus.package.jar.type>uber-jar</quarkus.package.jar.type>
		</properties>
	</profile>
	<profile>
		<id>duckdb</id>
		<properties>
			<polymr.database.variant>duckdb</polymr.database.variant>
			<polymr.build.suffix>duckdb</polymr.build.suffix>
			<quarkus.datasource.db-kind>other</quarkus.datasource.db-kind>
			<quarkus.datasource.jdbc.driver>org.duckdb.DuckDBDriver</quarkus.datasource.jdbc.driver>
			<quarkus.datasource.jdbc.url>jdbc:duckdb:${user.home}/.config/polymr/polymr.db</quarkus.datasource.jdbc.url>
			<quarkus.hibernate-orm.dialect>org.hibernate.dialect.PostgreSQLDialect</quarkus.hibernate-orm.dialect>
			<quarkus.hibernate-orm.mapping-files>no-file</quarkus.hibernate-orm.mapping-files>
		</properties>
		<dependencies>
			<dependency>
				<groupId>org.duckdb</groupId>
				<artifactId>duckdb_jdbc</artifactId>
				<version>1.5.3.0</version>
			</dependency>
			<dependency>
				<groupId>org.flywaydb</groupId>
				<artifactId>flyway-database-duckdb</artifactId>
				<version>10.24.0</version>
			</dependency>
		</dependencies>
		<activation>
			<property>
				<name>polymr.database.variant</name>
				<value>duckdb</value>
			</property>
		</activation>
	</profile>
	<profile>
		<id>hsqldb</id>
		<properties>
			<polymr.database.variant>hsqldb</polymr.database.variant>
			<polymr.build.suffix>hsqldb</polymr.build.suffix>
			<quarkus.datasource.db-kind>other</quarkus.datasource.db-kind>
			<quarkus.datasource.jdbc.driver>org.hsqldb.jdbc.JDBCDriver</quarkus.datasource.jdbc.driver>
			<quarkus.datasource.jdbc.url>jdbc:hsqldb:file:${user.home}/.config/polymr/polymr.hsqldb;hsqldb.tx=mvcc;hsqldb.default_table_type=cached;shutdown=true</quarkus.datasource.jdbc.url>
			<quarkus.hibernate-orm.dialect>org.hibernate.dialect.HSQLDialect</quarkus.hibernate-orm.dialect>
			<quarkus.hibernate-orm.mapping-files>META-INF/orm-hsqldb.xml</quarkus.hibernate-orm.mapping-files>
		</properties>
		<dependencies>
			<dependency>
				<groupId>org.hsqldb</groupId>
				<artifactId>hsqldb</artifactId>
				<version>2.7.4</version>
			</dependency>
			<dependency>
				<groupId>org.flywaydb</groupId>
				<artifactId>flyway-database-hsqldb</artifactId>
				<version>12.8.1</version>
			</dependency>
		</dependencies>
		<activation>
			<property>
				<name>polymr.database.variant</name>
				<value>hsqldb</value>
			</property>
		</activation>
	</profile>
	<profile>
		<id>sqlite</id>
		<properties>
			<polymr.database.variant>sqlite</polymr.database.variant>
			<polymr.build.suffix>sqlite</polymr.build.suffix>
			<quarkus.datasource.db-kind>other</quarkus.datasource.db-kind>
			<quarkus.datasource.jdbc.driver>org.sqlite.JDBC</quarkus.datasource.jdbc.driver>
			<quarkus.datasource.jdbc.url>jdbc:sqlite:${user.home}/.config/polymr/polymr.sqlite</quarkus.datasource.jdbc.url>
			<quarkus.hibernate-orm.dialect>org.hibernate.community.dialect.SQLiteDialect</quarkus.hibernate-orm.dialect>
			<quarkus.hibernate-orm.mapping-files>no-file</quarkus.hibernate-orm.mapping-files>
		</properties>
		<dependencies>
			<dependency>
				<groupId>org.xerial</groupId>
				<artifactId>sqlite-jdbc</artifactId>
				<version>3.50.3.0</version>
			</dependency>
			<dependency>
				<groupId>org.hibernate.orm</groupId>
				<artifactId>hibernate-community-dialects</artifactId>
			</dependency>
		</dependencies>
		<activation>
			<property>
				<name>polymr.database.variant</name>
				<value>sqlite</value>
			</property>
		</activation>
	</profile>
	<profile>
		<id>postgresql</id>
		<properties>
			<polymr.database.variant>postgresql</polymr.database.variant>
			<polymr.build.suffix>postgresql</polymr.build.suffix>
			<quarkus.datasource.db-kind>postgresql</quarkus.datasource.db-kind>
			<quarkus.datasource.jdbc.driver>org.postgresql.Driver</quarkus.datasource.jdbc.driver>
			<quarkus.datasource.jdbc.url>${DB_URL:jdbc:postgresql://localhost:5432/postgres}</quarkus.datasource.jdbc.url>
			<quarkus.hibernate-orm.dialect>org.hibernate.dialect.PostgreSQLDialect</quarkus.hibernate-orm.dialect>
			<quarkus.hibernate-orm.mapping-files>no-file</quarkus.hibernate-orm.mapping-files>
		</properties>
		<dependencies>
			<dependency>
				<groupId>io.quarkus</groupId>
				<artifactId>quarkus-jdbc-postgresql</artifactId>
			</dependency>
		</dependencies>
		<activation>
			<activeByDefault>true</activeByDefault>
		</activation>
	</profile>
    </profiles>
</project>
